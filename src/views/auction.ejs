<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Auction <%= dashboard.session.session_id %></title>
    <style>
      body {
        font-family: Arial, sans-serif;
        margin: 2rem;
        background: #eef2f7;
        color: #17212b;
      }
      .layout {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 1rem;
      }
      .card {
        background: #fff;
        border-radius: 12px;
        padding: 1.25rem;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
        margin-bottom: 1rem;
      }
      table {
        width: 100%;
        border-collapse: collapse;
      }
      th, td {
        padding: 0.65rem;
        border-bottom: 1px solid #e5e7eb;
        text-align: left;
      }
      form {
        margin: 0.5rem 0;
      }
      input, button {
        padding: 0.55rem 0.7rem;
        margin-right: 0.5rem;
      }
      .status {
        font-weight: bold;
      }
      .banner {
        background: #dff6dd;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        margin-bottom: 1rem;
        display: none;
      }
      @media (max-width: 900px) {
        .layout {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body
    data-page="auction"
    data-session-id="<%= dashboard.session.session_id %>"
    data-snapshot-token="<%= snapshotToken %>"
  >
    <p><a href="/">Back to home</a></p>
    <div id="liveBanner" class="banner">Live update received. Refreshing view...</div>

    <div class="card">
      <h1><%= dashboard.session.title %></h1>
      <p>Session ID: <strong><%= dashboard.session.session_id %></strong></p>
      <p class="status">Status: <%= dashboard.session.status %></p>
    </div>

    <div class="layout">
      <div>
        <div class="card">
          <h2>Current Basket</h2>
          <% if (!dashboard.currentBasket) { %>
            <p>No basket available.</p>
          <% } else { %>
            <p><strong>ID:</strong> <%= dashboard.currentBasket.basket_id %></p>
            <p><strong>Basket No:</strong> <%= dashboard.currentBasket.basket_no || "-" %></p>
            <p><strong>Description:</strong> <%= dashboard.currentBasket.description %></p>
            <p><strong>Status:</strong> <%= dashboard.currentBasket.status %></p>
            <p><strong>Starting Price:</strong> <%= dashboard.currentBasket.starting_price %></p>
            <p><strong>Highest Bid:</strong> <%= dashboard.currentBasket.highest_bid || "-" %></p>

            <% if (dashboard.currentBasket.status === "PENDING" || dashboard.currentBasket.status === "UNSOLD") { %>
              <form method="POST" action="/auction/<%= dashboard.session.session_id %>/baskets/<%= dashboard.currentBasket.basket_id %>/open">
                <button type="submit">Open Basket</button>
              </form>
            <% } %>

            <% if (dashboard.currentBasket.status === "OPEN") { %>
              <form method="POST" action="/auction/<%= dashboard.session.session_id %>/baskets/<%= dashboard.currentBasket.basket_id %>/bid">
                <input type="text" name="bidderId" placeholder="Bidder ID" required />
                <input type="text" name="bidderName" placeholder="Bidder Name" required />
                <input type="number" step="0.01" min="0" name="amount" placeholder="Bid amount" required />
                <button type="submit">Place Bid</button>
              </form>

              <form method="POST" action="/auction/<%= dashboard.session.session_id %>/baskets/<%= dashboard.currentBasket.basket_id %>/close">
                <button type="submit">Close Basket</button>
              </form>
            <% } %>

            <% if (dashboard.currentBasket.status === "SOLD") { %>
              <form method="POST" action="/auction/<%= dashboard.session.session_id %>/baskets/<%= dashboard.currentBasket.basket_id %>/payment/confirm">
                <button type="submit">Confirm Payment</button>
              </form>
            <% } %>
          <% } %>
        </div>

        <div class="card">
          <h2>Current Basket Bids</h2>
          <% if (!dashboard.bids.length) { %>
            <p>No bids yet.</p>
          <% } else { %>
            <table>
              <thead>
                <tr>
                  <th>Bidder</th>
                  <th>Amount</th>
                  <th>Placed At</th>
                </tr>
              </thead>
              <tbody>
                <% dashboard.bids.forEach((bid) => { %>
                  <tr>
                    <td><%= bid.bidder_name %> (<%= bid.bidder_id %>)</td>
                    <td><%= bid.amount %></td>
                    <td><%= new Date(bid.placed_at).toLocaleString() %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>

        <div class="card">
          <h2>All Baskets</h2>
          <table>
            <thead>
              <tr>
                <th>Basket</th>
                <th>Description</th>
                <th>Status</th>
                <th>Highest Bid</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% dashboard.baskets.forEach((basket) => { %>
                <tr>
                  <td><%= basket.basket_no || basket.basket_id %></td>
                  <td><%= basket.description %></td>
                  <td><%= basket.status %></td>
                  <td><%= basket.highest_bid || "-" %></td>
                  <td>
                    <% if (basket.status === "PENDING" || basket.status === "UNSOLD") { %>
                      <form method="POST" action="/auction/<%= dashboard.session.session_id %>/baskets/<%= basket.basket_id %>/open">
                        <button type="submit">Open</button>
                      </form>
                    <% } else if (basket.status === "OPEN") { %>
                      <form method="POST" action="/auction/<%= dashboard.session.session_id %>/baskets/<%= basket.basket_id %>/close">
                        <button type="submit">Close</button>
                      </form>
                    <% } else if (basket.status === "SOLD") { %>
                      <% const sale = dashboard.sales.find((item) => item.basket_id === basket.basket_id); %>
                      <% if (sale && !sale.payment_confirmed) { %>
                        <form method="POST" action="/auction/<%= dashboard.session.session_id %>/baskets/<%= basket.basket_id %>/payment/confirm">
                          <button type="submit">Confirm Payment</button>
                        </form>
                      <% } else { %>
                        <span>-</span>
                      <% } %>
                    <% } else { %>
                      <span>-</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <div>
        <div class="card">
          <h2>Rebid Queue</h2>
          <% if (!dashboard.rebidQueue.length) { %>
            <p>Queue is empty.</p>
          <% } else { %>
            <table>
              <thead>
                <tr>
                  <th>Basket</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% dashboard.rebidQueue.forEach((item) => { %>
                  <tr>
                    <td><%= item.basket_no || item.basket_id %> - <%= item.description %></td>
                    <td><%= item.status %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>

        <div class="card">
          <h2>Sale Records</h2>
          <% if (!dashboard.sales.length) { %>
            <p>No completed sales yet.</p>
          <% } else { %>
            <table>
              <thead>
                <tr>
                  <th>Basket</th>
                  <th>Winner</th>
                  <th>Amount</th>
                  <th>Paid</th>
                </tr>
              </thead>
              <tbody>
                <% dashboard.sales.forEach((sale) => { %>
                  <tr>
                    <td><%= sale.basket_id %></td>
                    <td><%= sale.winner_id %></td>
                    <td><%= sale.winning_bid_amount %></td>
                    <td><%= sale.payment_confirmed ? "Yes" : "No" %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/main.js"></script>
  </body>
</html>
